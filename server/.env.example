# SendGrid API configuration (for reliable email sending)
# Get API Key from: https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=your-sendgrid-api-key-here
SENDGRID_FROM_EMAIL=kontakt@galaretkarnia.pl

# Business email (where orders go)
ORDER_EMAIL=kontakt@galaretkarnia.pl

# Frontend URL (for CORS)
FRONTEND_URL=https://galaretkarnia-pl.vercel.app

# Environment
NODE_ENV=production
PORT=3001

# Optional: Send confirmation to customer?
CUSTOMER_EMAIL_FIELD=false
