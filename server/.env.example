# Example environment variables
PORT=3001
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/dbname
# Optional explicit DB name for default mode
MONGODB_DB_NAME=galaretkarnia

# Optional explicit collection names
ORDERS_COLLECTION=orders
ORDERS_COLLECTION_TEST=orders_test

# Optional explicit DB name for test mode (NODE_ENV=test)
MONGODB_DB_NAME_TEST=galaretkarnia

RESEND_API_KEY=your-resend-api-key
RESEND_FROM_EMAIL=your@email.com
ORDER_EMAIL=recipient@email.com

# Optional separate inbox for live E2E / test orders
ORDER_EMAIL_TEST=recipient-test@email.com

# Auto-cleanup of test orders (days). Used only in NODE_ENV=test
TEST_ORDER_TTL_DAYS=14
