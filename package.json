{
  "type": "module",
  "dependencies": {
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "mongodb": "^7.1.0",
    "node-fetch": "^3.3.2",
    "resend": "^6.9.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@secretlint/secretlint-rule-preset-recommend": "^11.2.4",
    "@types/jest": "^30.0.0",
    "@vitejs/plugin-basic-ssl": "^2.3.0",
    "concurrently": "^8.2.2",
    "imagemin": "^9.0.1",
    "imagemin-mozjpeg": "^10.0.0",
    "imagemin-pngquant": "^10.0.0",
    "imagemin-webp": "^8.0.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "playwright": "^1.58.2",
    "secretlint": "^11.2.4",
    "simple-git-hooks": "^2.13.1",
    "ts-jest": "^29.4.6",
    "vite": "^8.0.3",
    "vite-plugin-webp": "^1.1.3"
  },
  "scripts": {
    "compress:images": "node ./scripts/compress-images.mjs",
    "dev": "concurrently \"npm run dev --prefix client\" \"npm run dev --prefix server\"",
    "dev:test": "concurrently \"npm run dev --prefix client\" \"npm run dev:test --prefix server\"",
    "dev:prodlike": "npm run build --prefix client && node server/server.mjs",
    "dev:prodlike:client": "npm run build --prefix client && npm run preview --prefix client",
    "build": "npm run build --prefix client",
    "build:vercel": "npm run build --prefix client && node ./scripts/sync-vercel-dist.mjs",
    "start": "npm run build && node server/server.mjs",
    "prepare": "simple-git-hooks",
    "secrets:check:staged": "node ./scripts/secretlint-staged.mjs",
    "stop": "taskkill /F /IM node.exe || exit 0",
    "restart": "npm run stop && npm run dev",
    "test:e2e": "npm run test:e2e:smoke",
    "test:e2e:all": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:smoke": "playwright test tests/e2e/smoke.spec.ts",
    "test:e2e:live": "playwright test -c playwright.live.config.ts tests/e2e/checkout-live.spec.ts --workers=1"
  },
  "simple-git-hooks": {
    "pre-commit": "npm run secrets:check:staged"
  },
  "test": "echo \"No tests specified\""
}
