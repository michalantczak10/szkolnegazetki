{
  "private": true,
  "type": "module",
  "dependencies": {
    "dotenv": "^16.3.1",
    "mongodb": "^7.1.0",
    "resend": "^6.9.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@secretlint/secretlint-rule-preset-recommend": "^11.2.4",
    "@types/jest": "^30.0.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "playwright": "^1.58.2",
    "secretlint": "^11.2.4",
    "sharp": "^0.33.5",
    "simple-git-hooks": "^2.13.1",
    "stylelint": "^17.4.0",
    "stylelint-config-standard": "^40.0.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.0.0",
    "vite": "^7.3.2"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "start": "npm run build",
    "preview": "vite preview",
    "prepare": "simple-git-hooks",
    "secrets:check:staged": "node ./scripts/secretlint-staged.mjs",
    "test:e2e": "npm run test:e2e:smoke",
    "test:e2e:all": "playwright test",
    "test:e2e:smoke": "playwright test tests/e2e/smoke.spec.ts",
    "test:e2e:live": "playwright test -c playwright.live.config.ts",
    "test:prod:smoke": "node ./scripts/prod-smoke.mjs",
    "ops:local:check": "node ./scripts/local-housekeeping.mjs",
    "ops:local:cleanup": "node ./scripts/local-housekeeping.mjs --delete-merged"
  },
  "simple-git-hooks": {
    "pre-commit": "npm run secrets:check:staged"
  }
}
