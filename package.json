{
  "private": true,
  "type": "module",
  "dependencies": {
    "dotenv": "^16.3.1",
    "mongodb": "^7.1.0",
    "resend": "^6.1.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@secretlint/secretlint-rule-preset-recommend": "^11.2.4",
    "@vercel/node": "^5.7.15",
    "concurrently": "^9.2.1",
    "playwright": "^1.58.2",
    "secretlint": "^11.2.4",
    "sharp": "^0.33.5",
    "simple-git-hooks": "^2.13.1",
    "stylelint": "^17.4.0",
    "stylelint-config-standard": "^40.0.0",
    "typescript": "^5.0.0",
    "tsx": "^4.20.6",
    "vite": "^7.3.2"
  },
  "scripts": {
    "dev": "vite",
    "dev:api": "tsx watch scripts/dev-api.ts",
    "dev:full": "concurrently -n FE,API -c blue,green \"npm:dev\" \"npm:dev:api\"",
    "dev:test": "vite",
    "build": "vite build",
    "start": "npm run build",
    "preview": "vite preview",
    "prepare": "simple-git-hooks",
    "secrets:check:staged": "node ./scripts/secretlint-staged.mjs",
    "test:e2e": "npm run test:e2e:smoke",
    "test:api": "tsx --test tests/api/orders.test.ts",
    "test:verify": "npm run build && npm run test:api && npm run test:coverage && npm run test:e2e:smoke",
    "test:e2e:all": "playwright test",
    "test:e2e:smoke": "playwright test tests/e2e/smoke.spec.ts",
    "test:e2e:live": "playwright test -c playwright.live.config.ts",
    "test:prod:smoke": "node ./scripts/prod-smoke.mjs",
    "ops:local:check": "node ./scripts/local-housekeeping.mjs",
    "ops:local:cleanup": "node ./scripts/local-housekeeping.mjs --delete-merged",
    "assets:previews": "node ./scripts/generate-product-previews.mjs",
    "test:coverage": "node ./scripts/check-test-coverage.mjs",
    "structure:sync": "node ./scripts/export-previews-structure-csv.mjs"
  },
  "simple-git-hooks": {
    "pre-commit": "npm run secrets:check:staged",
    "pre-push": "npm run test:coverage"
  }
}
